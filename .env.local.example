# ============================================================
# 환경변수 설정 파일 예시
# 이 파일을 복사하여 .env.local 파일을 만드세요
# cp .env.local.example .env.local
# ============================================================

# ── Supabase 설정 (필수) ───────────────────────────────────
# Supabase 프로젝트 URL (https://supabase.com/dashboard에서 확인)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co

# Supabase 공개 키 (anon key)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase 서비스 롤 키 (서버에서만 사용, 절대 공개하지 마세요!)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── AI API 설정 (선택사항, 없으면 기본 텍스트 요약으로 동작) ──
# Groq API Key (무료: https://console.groq.com/keys)
# llama-3.1-8b-instant 모델 사용 (무료 티어: 30 RPM, 14,400 req/day)
GROQ_API_KEY=gsk_...

# ── 이메일 발송 설정 (선택사항) ───────────────────────────
# Gmail SMTP 사용 방법:
# 1. Google 계정 → 보안 → 2단계 인증 활성화
# 2. Google 계정 → 보안 → 앱 비밀번호 생성
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here

# 뉴스레터 발송자 이름
SMTP_FROM_NAME=CB본부 뉴스레터

# 기본 수신 이메일
DEFAULT_RECIPIENT=ceo@company.com

# ── Cron 보안 키 (자동 수집용) ────────────────────────────
# 아무 문자열이나 입력하세요 (예: openssl rand -hex 32)
CRON_SECRET=your-super-secret-cron-key-here

# ── 앱 URL (Vercel 배포 시 변경) ──────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
